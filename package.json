{
  "name": "wiki-race",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter shared build && concurrently \"pnpm --filter api dev\" \"pnpm --filter web dev\"",
    "start:front": "pnpm --filter web dev",
    "start:back": "pnpm --filter api dev",
    "build": "pnpm --filter shared build && pnpm --filter api build && pnpm --filter web build",
    "test": "pnpm --filter api test && pnpm --filter web test",
    "lint": "eslint \"apps/**/*.{ts,vue}\" \"packages/**/*.ts\"",
    "format": "prettier --write \"apps/**/*.{ts,vue}\" \"packages/**/*.ts\"",
    "changeset": "changeset",
    "bump": "changeset version",
    "release": "node scripts/release.mjs"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
